// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "inlay_hints": {
    "enabled": true
  },
  "outline_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  "always_treat_brackets_as_autoclosed": true,
  "session": {
    "trust_all_worktrees": true
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "debugger": {
    "dock": "left"
  },
  "icon_theme": "VSCode Icons for Zed (Dark Angular)",
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "terminal": {
    "cursor_shape": "bar",
    "copy_on_select": true,
  },
  "preview_tabs": {
    "enabled": true,
  },
  "current_line_highlight": "all",
  "cursor_blink": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "show_whitespaces": "all",
  "soft_wrap": "editor_width",
  "base_keymap": "Cursor",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python"
        }
      }
    }
  },
  "languages": {
    "Proto": {
      "formatter": {
        "external": {
          "command": "buf",
          "arguments": ["format", "-"]
        }
      },
      "format_on_save": "on"
    }
  }
}
